rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSafeString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function isDateInput(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isIsoDate(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}T.*Z$');
    }

    function isNullableDate(value) {
      return value == null || isDateInput(value);
    }

    function isNullableIsoDate(value) {
      return value == null || isIsoDate(value);
    }

    function isAllowedPlatform(value) {
      return value in ['Wallapop', 'Vinted'];
    }

    function isAllowedCategory(value) {
      return value in [
        'Electrónica',
        'Ropa',
        'Hogar',
        'Juguetes',
        'Belleza',
        'Deporte',
        'Libros/Media',
        'Accesorios',
        'Otros'
      ];
    }

    function isAllowedCondition(value) {
      return value in ['Nuevo', 'Bueno', 'Aceptable', 'Dañado'];
    }

    function isAllowedStatus(value) {
      return value in ['Pendiente', 'En venta', 'Vendido', 'Descartado', 'Me lo quedo'];
    }

    function isValidPackageShape(packageId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'date',
          'cost',
          'notes',
          'addedBy',
          'addedAt',
          'updatedAt',
          'updatedBy'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'date',
          'cost',
          'notes',
          'addedBy',
          'addedAt'
        ])
        && request.resource.data.id == packageId
        && isDateInput(request.resource.data.date)
        && request.resource.data.cost is number
        && request.resource.data.cost > 0
        && request.resource.data.cost <= 100000
        && isSafeString(request.resource.data.notes, 500)
        && isSafeString(request.resource.data.addedBy, 120)
        && isIsoDate(request.resource.data.addedAt)
        && isNullableIsoDate(request.resource.data.updatedAt)
        && (request.resource.data.updatedBy == null || isSafeString(request.resource.data.updatedBy, 120));
    }

    function isValidProductShape(productId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'name',
          'category',
          'packageId',
          'condition',
          'quantity',
          'estPrice',
          'status',
          'notes',
          'createdAt',
          'updatedAt',
          'soldQuantity',
          'soldPrice',
          'soldUnitPrice',
          'soldPlatform',
          'soldDate',
          'soldBy',
          'addedBy',
          'sales',
          'sourceProductId'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'name',
          'category',
          'packageId',
          'condition',
          'quantity',
          'estPrice',
          'status',
          'notes',
          'createdAt',
          'soldQuantity',
          'soldPrice',
          'soldPlatform',
          'soldDate',
          'addedBy'
        ])
        && request.resource.data.id == productId
        && isSafeString(request.resource.data.name, 160)
        && isAllowedCategory(request.resource.data.category)
        && isSafeString(request.resource.data.packageId, 120)
        && isAllowedCondition(request.resource.data.condition)
        && request.resource.data.quantity is int
        && request.resource.data.quantity >= 1
        && request.resource.data.quantity <= 500
        && request.resource.data.estPrice is number
        && request.resource.data.estPrice >= 0
        && request.resource.data.estPrice <= 100000
        && isAllowedStatus(request.resource.data.status)
        && isSafeString(request.resource.data.notes, 1000)
        && isIsoDate(request.resource.data.createdAt)
        && isNullableIsoDate(request.resource.data.updatedAt)
        && request.resource.data.soldQuantity is int
        && request.resource.data.soldQuantity >= 0
        && request.resource.data.soldQuantity <= request.resource.data.quantity
        && request.resource.data.soldPrice is number
        && request.resource.data.soldPrice >= 0
        && request.resource.data.soldPrice <= 100000
        && (request.resource.data.soldUnitPrice == null || (
          request.resource.data.soldUnitPrice is number
          && request.resource.data.soldUnitPrice >= 0
          && request.resource.data.soldUnitPrice <= 100000
        ))
        && (request.resource.data.soldPlatform == null || isAllowedPlatform(request.resource.data.soldPlatform))
        && isNullableDate(request.resource.data.soldDate)
        && (request.resource.data.soldBy == null || isSafeString(request.resource.data.soldBy, 120))
        && isSafeString(request.resource.data.addedBy, 120)
        && (!('sourceProductId' in request.resource.data) || isSafeString(request.resource.data.sourceProductId, 120))
        && (!('sales' in request.resource.data) || request.resource.data.sales is list);
    }

    match /packages/{packageId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidPackageShape(packageId);
      allow delete: if isSignedIn();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidProductShape(productId);
      allow delete: if isSignedIn();
    }
  }
}
